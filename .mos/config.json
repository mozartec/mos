{
  "specVersion": "0.4",
  "vault": { "name": "Markdown on Steroids" },

  "meta": {
    "timestamps": { "createdField": "created", "updatedField": "updated" }
  },

  "fields": {
    "id": { "type": "id", "label": "ID" },
    "title": { "type": "string", "label": "Title" },
    "status": { "type": "string", "label": "Status" },
    "phase": { "type": "enum", "values": ["MVP", "Phase 2", "Phase 3", "Phase 4", "Future"], "label": "Phase", "icon": "tag" },
    "priority": { "type": "enum", "values": ["P0", "P1", "P2", "P3"], "label": "Priority", "icon": "flag", "valueColors": { "P0": "red", "P1": "amber", "P2": "blue", "P3": "slate" } },
    "owner": { "type": "string", "label": "Owner", "icon": "user" },
    "estimate": { "type": "enum", "values": ["XS", "S", "M", "L", "XL"], "label": "Estimate", "icon": "hourglass" },
    "parent": { "type": "id", "label": "Parent", "icon": "git-commit" },
    "dependsOn": { "type": "id", "list": true, "label": "Depends on", "icon": "git-commit" },
    "touches": { "type": "enum", "source": "areas", "list": true, "label": "Touches", "icon": "stack" },
    "created": { "type": "datetime", "label": "Created", "icon": "clock" },
    "updated": { "type": "datetime", "label": "Updated", "icon": "clock" }
  },

  "areas": {
    "core": ["packages/core/**"],
    "server": ["packages/vault-server/**", "apps/dev-server/**"],
    "cli": ["apps/cli/**"],
    "web": ["apps/web/**"],
    "desktop": ["apps/desktop/**"],
    "mcp": ["apps/mcp/**"],
    "vscode": ["apps/vscode/**"],
    "skills": ["skills/**", ".agents/skills/**", "skills-lock.json"],
    "docs": ["docs/**", "*.md"],
    "board": ["board/**"],
    "config": [".mos/**"],
    "scripts": ["scripts/**"],
    "ci": [".github/**"]
  },

  "wiki": {
    "include": ["**/*.md"],
    "exclude": [".mos/**", "AGENTS.md", "CLAUDE.md", "node_modules/**", "examples/**", "apps/**", "packages/**", "skills/**", "dist/**", ".turbo/**", ".git/**"],
    "fields": ["created", "updated"]
  },

  "board": {
    "include": ["board/**/*.md"],
    "columns": ["Backlog", "Planned", "In Progress", "Done"],
    "sortWithinColumn": ["priority", "id"]
  },

  "references": {
    "idPattern": "[A-Z][A-Z0-9]*-[0-9]+(?:-[A-Z]+-[0-9]+)*"
  },

  "types": {
    "feature": {
      "label": "Feature",
      "parent": null,
      "color": "purple",
      "states": {
        "Draft": "Backlog",
        "Planned": "Planned",
        "In Progress": "In Progress",
        "Done": "Done",
        "Deferred": null,
        "Dropped": null
      },
      "card": { "fields": ["id", "phase", "priority", "owner", "dependsOn", "touches", "created", "updated"] }
    },
    "story": {
      "label": "Story",
      "parent": "feature",
      "color": "green",
      "states": {
        "Todo": "Backlog",
        "Planned": "Planned",
        "In Progress": "In Progress",
        "Blocked": "In Progress",
        "Done": "Done"
      },
      "card": { "fields": ["id", "parent", "priority", "owner", "estimate", "dependsOn", "touches", "created", "updated"] }
    },
    "task": {
      "label": "Task",
      "parent": null,
      "color": "blue",
      "states": {
        "Todo": "Backlog",
        "Planned": "Planned",
        "In Progress": "In Progress",
        "Done": "Done",
        "Deferred": null
      },
      "card": { "fields": ["id", "phase", "priority", "owner", "dependsOn", "touches", "created", "updated"] }
    }
  }
}
